{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 4,

  "modules-left": [
    "wireplumber",
    "custom/sep",
    "hyprland/workspaces",
    "custom/sep",
    "custom/spotify"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "custom/weather",
    "custom/sep",
    "cpu",
    "memory",
    "disk",
    "custom/sep",
    "clock"
  ],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{name}"
  },
  "hyprland/window": {
    "max-length": 120,
    "seperate-outputs": false
  },
  "tray": {
    "spacing": 10
  },
  "wireplumber": {
    "format": " {icon} {volume:3}%",
    "format-muted": "      ",
    "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
    "format-icons": ["", ""]
  },
  "clock": {
    "format": "<span color='#888888'></span>  {:%H:%M}",
    "format-alt": "<span color='#888888'></span>  {:%Y-%m-%d}",
    "tooltip": false
  },
  "cpu": {
    "format": "<span color='#888888'></span>  {usage}%",
    "tooltip": false
  },
  "memory": {
    "format": "<span color='#888888'></span>  {used:.0f}%"
  },
  "disk": {
    "interval": 60,
    "path": "/",
    "format": "<span color='#888888'></span>  {specific_free:.0f} GB",
    "unit": "GB"
  },
  "custom/sep": {
    "format": " ",
    "interval": 0
  },
  "custom/spotify": {
    "exec": "playerctl --player=spotify metadata --format '  {{ artist }} - {{ title }}' 2>/dev/null || echo ''",
    "interval": 5,
    "exec-if": "pgrep -f spotify",
    "on-click": "playerctl --player=spotify play-pause",
    "on-click-right": "playerctl --player=spotify next"
  },
  "custom/weather": {
    "exec": "waybar-weather",
    "interval": 600,
    "format": "{}",
    "tooltip": true,
    "return-type": "json"
  }
}
