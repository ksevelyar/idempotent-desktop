{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 4,

  "modules-left": [
    "wireplumber",
    "custom/sep",
    "hyprland/workspaces",
    "custom/sep",
    "custom/spotify",
    "custom/sep"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "custom/weather",
    "custom/sep",
    "cpu",
    "memory",
    "disk",
    "custom/sep",
    "clock"
  ],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{name}"
  },
  "hyprland/window": {
    "max-length": 120,
    "seperate-outputs": false
  },
  "wireplumber": {
    "format": " <span color='#6a6a7a'>{icon}</span>{volume:3}%",
    "format-muted": " <span color='#6a6a7a'></span>    ",
    "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
    "format-icons": [""]
  },
  "clock": {
    "locale": "en_GB.UTF-8",
    "format": "<span color='#6a6a7a'></span> {:%H:%M}",
    "format-alt": "<span color='#6a6a7a'></span> {:%a %d-%m-%y %H:%M}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "iso8601": true,
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "",
      "on-scroll": 1,
      "format": {
        "days": "<span color='#6a6a7a'><b>{}</b></span>",
        "today": "<span color='#fff'><b>{}</b></span>"
      }
    },
    "actions":  {
      "on-click-right": "mode"
    }
  },
  "cpu": {
    "format": "<span color='#6a6a7a'></span> {usage}%"
  },
  "memory": {
    "format": "<span color='#6a6a7a'> </span>{used:.0f}%"
  },
  "disk": {
    "interval": 60,
    "path": "/",
    "format": "<span color='#6a6a7a'></span> {specific_free:.0f} GB",
    "unit": "GB"
  },
  "custom/sep": {
    "format": " ",
    "interval": 0
  },
  "custom/spotify": {
    "exec": "playerctl --player=spotify metadata --format '<span color=\"#6a6a7a\"></span> {{ artist }} - {{ title }}' 2>/dev/null | sed 's/&/\\&amp;/g'",
    "tooltip": false,
    "interval": 5,
    "exec-if": "pgrep -f spotify",
    "on-click": "playerctl --player=spotify play-pause",
    "on-click-right": "playerctl --player=spotify next",
  },
  "custom/weather": {
    "exec": "waybar-weather",
    "interval": 300,
    "format": "{}",
    "tooltip": true,
    "return-type": "json"
  }
}
